# Runtime environment for /var/lib/withings-mcp/env on the Hetzner host.
# Copy to the server, fill real values, then chmod 0640 and chgrp withings-mcp.

# Withings OAuth app credentials from https://developer.withings.com/
WITHINGS_CLIENT_ID=your_client_id_here
WITHINGS_CLIENT_SECRET=your_client_secret_here
WITHINGS_REDIRECT_URI=https://withings.example.com/callback

# Generate with: bun run generate-secret
# or: openssl rand -hex 32
ENCRYPTION_SECRET=replace_with_at_least_32_random_chars

# Supabase project credentials. Apply upstream migrations before first run.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_service_role_key_here

# Server runtime. Caddy/nginx should reverse-proxy your public domain to this port.
PORT=3000
LOG_LEVEL=info

# Optional browser CORS allow-list. Native MCP clients usually omit Origin.
# ALLOWED_ORIGINS=https://withings.example.com
