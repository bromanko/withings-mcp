#!/usr/bin/env bash
# shellcheck disable=SC2029
set -euo pipefail

# One-time systemd bootstrap for a mutable Linux Hetzner host. Run as root.
#
# Usage:
#   scripts/install-service root@<server-ip>
#
# NixOS note:
#   NixOS manages /etc/systemd/system declaratively, so this imperative installer
#   is expected to fail there. Import deploy/nixos/withings-mcp.nix into the host
#   NixOS config instead.
#
# After this, populate /var/lib/withings-mcp/env on the server and run scripts/deploy.

SSH_TARGET="${1:-${DEPLOY_HOST:-}}"

if [[ -z $SSH_TARGET ]]; then
  echo "Usage: $0 <ssh-target>" >&2
  echo "Example: $0 root@5.78.44.117" >&2
  exit 1
fi

require() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: required command not found: $1" >&2
    exit 1
  fi
}

require ssh
require scp

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
UNIT_SRC="$REPO_ROOT/deploy/systemd/withings-mcp.service"

if [[ ! -f $UNIT_SRC ]]; then
  echo "ERROR: missing systemd unit at $UNIT_SRC" >&2
  exit 1
fi

print_nixos_help() {
  cat >&2 <<'EOF'

This host does not allow writing to /etc/systemd/system. If it is NixOS,
that is expected: systemd units are managed by the NixOS configuration.

Use the declarative module in this repo instead:

  1. Copy or reference deploy/nixos/withings-mcp.nix from your host config.
  2. Add something like this to configuration.nix or your flake host module:

       imports = [ /path/to/withings-mcp/deploy/nixos/withings-mcp.nix ];
       services.withings-mcp.enable = true;

  3. Rebuild the host:

       nixos-rebuild switch

  4. Populate /var/lib/withings-mcp/env, then run scripts/deploy.

EOF
}

echo "==> Checking systemd unit install path"
if ! ssh "$SSH_TARGET" "
  set -euo pipefail
  test -d /etc/systemd/system
  touch /etc/systemd/system/.withings-mcp-write-test
  rm -f /etc/systemd/system/.withings-mcp-write-test
"; then
  print_nixos_help
  exit 1
fi

echo "==> Creating service user and directories"
ssh "$SSH_TARGET" "
  set -euo pipefail
  if ! getent group withings-mcp >/dev/null 2>&1; then
    groupadd --system withings-mcp
  fi
  if ! id -u withings-mcp >/dev/null 2>&1; then
    useradd --system --gid withings-mcp --home-dir /var/lib/withings-mcp --shell /usr/sbin/nologin withings-mcp
  fi
  install -d -o withings-mcp -g withings-mcp -m 0750 /var/lib/withings-mcp /var/lib/withings-mcp/releases
  if [ ! -f /var/lib/withings-mcp/env ]; then
    install -o root -g withings-mcp -m 0640 /dev/null /var/lib/withings-mcp/env
  fi
"

echo "==> Installing systemd unit"
scp "$UNIT_SRC" "$SSH_TARGET:/tmp/withings-mcp.service"
if ! ssh "$SSH_TARGET" "
  set -euo pipefail
  install -o root -g root -m 0644 /tmp/withings-mcp.service /etc/systemd/system/withings-mcp.service
  rm -f /tmp/withings-mcp.service
  systemctl daemon-reload
  systemctl enable withings-mcp
"; then
  print_nixos_help
  exit 1
fi

echo "==> Done"
echo "Populate /var/lib/withings-mcp/env, then run: scripts/deploy $SSH_TARGET"
