#!/usr/bin/env bash
# shellcheck disable=SC2029
set -euo pipefail

# One-time systemd bootstrap for the Hetzner host. Run as root.
#
# Usage:
#   scripts/install-service root@<server-ip>
#
# After this, populate /var/lib/withings-mcp/env on the server and run scripts/deploy.

SSH_TARGET="${1:-${DEPLOY_HOST:-}}"

if [[ -z $SSH_TARGET ]]; then
  echo "Usage: $0 <ssh-target>" >&2
  echo "Example: $0 root@5.78.44.117" >&2
  exit 1
fi

require() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: required command not found: $1" >&2
    exit 1
  fi
}

require ssh
require scp

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
UNIT_SRC="$REPO_ROOT/deploy/systemd/withings-mcp.service"

if [[ ! -f $UNIT_SRC ]]; then
  echo "ERROR: missing systemd unit at $UNIT_SRC" >&2
  exit 1
fi

echo "==> Creating service user and directories"
ssh "$SSH_TARGET" "
  set -euo pipefail
  if ! getent group withings-mcp >/dev/null 2>&1; then
    groupadd --system withings-mcp
  fi
  if ! id -u withings-mcp >/dev/null 2>&1; then
    useradd --system --gid withings-mcp --home-dir /var/lib/withings-mcp --shell /usr/sbin/nologin withings-mcp
  fi
  install -d -o withings-mcp -g withings-mcp -m 0750 /var/lib/withings-mcp /var/lib/withings-mcp/releases
  if [ ! -f /var/lib/withings-mcp/env ]; then
    install -o root -g withings-mcp -m 0640 /dev/null /var/lib/withings-mcp/env
  fi
"

echo "==> Installing systemd unit"
scp "$UNIT_SRC" "$SSH_TARGET:/tmp/withings-mcp.service"
ssh "$SSH_TARGET" "
  set -euo pipefail
  mv /tmp/withings-mcp.service /etc/systemd/system/withings-mcp.service
  chown root:root /etc/systemd/system/withings-mcp.service
  chmod 0644 /etc/systemd/system/withings-mcp.service
  systemctl daemon-reload
  systemctl enable withings-mcp
"

echo "==> Done"
echo "Populate /var/lib/withings-mcp/env, then run: scripts/deploy $SSH_TARGET"
