# Example Caddy reverse proxy for a Hetzner host.
#
# Replace with your real domain, then point your Withings OAuth redirect URI at:
#   https://withings.example.com/callback
#
# MCP endpoint for clients:
#   https://withings.example.com/mcp

withings.example.com {
  encode zstd gzip
  reverse_proxy 127.0.0.1:3000
}
